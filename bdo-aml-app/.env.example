# Microsoft Azure AD (MSAL)
VITE_AZURE_CLIENT_ID=232439e8-2b9d-46cc-9ef5-b8cce8521b3e
VITE_AZURE_TENANT_ID=be3d2a5f-945c-469b-bb8a-2c50395c4601
VITE_REDIRECT_URI=http://localhost:3000

# SharePoint — BDO Audit Software Dev Site
VITE_SP_HOSTNAME=bdozw.sharepoint.com
VITE_SP_SITE_PATH=/sites/AuditSoftwareDevSite
VITE_SHAREPOINT_SITE_URL=https://bdozw.sharepoint.com/sites/AuditSoftwareDevSite

# Optional list GUID overrides (leave empty to auto-resolve by list name on the site)
# Copy from SharePoint → List settings → List ID if you want to pin IDs
VITE_SP_LIST_CLIENT_ONBOARDING=
VITE_SP_LIST_DIRECTORS=
VITE_SP_LIST_BENEFICIAL_OWNERS=
VITE_SP_LIST_AUDIT_LOGS=
VITE_SP_LIBRARY_AML_DOCUMENTS=

# Set to true to use browser localStorage instead of SharePoint
VITE_USE_SHAREPOINT_MOCK=false
